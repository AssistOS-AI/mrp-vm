    "supportedActs": ["compare", "diagnose", "explain", "recommend", "verify"],
    "topicTags": ["general", "technical", "legal", "literature"],
    "preferredDepth": "deep",
    "fallbackRole": "heavy-recovery",
    "confidenceWhenMatched": 0.8
  }
